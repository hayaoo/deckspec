{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@deckspec/dsl": ["./packages/dsl/src"],
      "@deckspec/schema": ["./packages/schema/src"],
      "@deckspec/renderer": ["./packages/renderer/src"],
      "@deckspec/cli": ["./packages/cli/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
